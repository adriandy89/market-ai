# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV="development"
API_PORT=3001
SWAGGER_ENABLE=true
COOKIE_DOMAIN=".market-ai.com"

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5436/marketaidb?schema=public&connection_limit=20"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="Data_Redis_p6379"

# ============================================
# SESSION
# ============================================
SESSION_SECRET="change-this-to-a-random-32-char-hex-string-in-production"

# ============================================
# EMAIL CONFIGURATION
# ============================================
PUBLIC_APP_URL=http://localhost:4201
EMAIL_USER=email@gmail.com
EMAIL_PASS=password

# ============================================
# AI CONFIGURATION (Anthropic Claude)
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# COINGECKO API (free demo key from coingecko.com/en/api/pricing)
# ============================================
COINGECKO_API_KEY=your-coingecko-demo-api-key

# ============================================
# CRYPTOCOMPARE API (free key from cryptocompare.com/cryptopiano/api-keys)
# ============================================
CRYPTOCOMPARE_API_KEY=your-cryptocompare-api-key


# ============================================
# TELEGRAM CONFIGURATION
# ============================================
# 1. Create a Telegram bot:
#    - Open Telegram and search for "BotFather" (@BotFather)
#    - Send command: /newbot
#    - Follow instructions to name your bot
#    - Copy the generated HTTP API Token
# TELEGRAM_BOT_TOKEN="YOUR_REAL_BOT_TOKEN_HERE"
# 2. Configure Webhook (For local development with ngrok):
#    - Install ngrok: npm install -g ngrok
#    - Configure token: ngrok config add-authtoken 37fgJyw9TU2RiUF9gO8BkNOgqlR_7u7FEaFc3YG8nSvz68xFT
#    - Run: ./start-ngrok.sh
#    - Copy the generated HTTPS URL below and append /api/v1/telegram/webhook
# TELEGRAM_WEBHOOK_URL="https://your-ngrok-url.ngrok-free.app/api/v1/telegram/webhook"
# TELEGRAM_WEBHOOK_SECRET="dev_webhook_secret_123"
# TELEGRAM_BOT_LINK="https://t.me/your_bot_username"

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_LINK=https://t.me/Cripto_Market_AI_bot
