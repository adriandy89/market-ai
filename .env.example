# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV="development"
API_PORT=3001
SWAGGER_ENABLE=true
COOKIE_DOMAIN=".market-ai.com"

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5436/marketaidb?schema=public&connection_limit=20"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="Data_Redis_p6379"

# ============================================
# SESSION
# ============================================
SESSION_SECRET="change-this-to-a-random-32-char-hex-string-in-production"

# ============================================
# EMAIL CONFIGURATION
# ============================================
PUBLIC_APP_URL=http://localhost:4201
EMAIL_USER=email@gmail.com
EMAIL_PASS=password

# ============================================
# AI CONFIGURATION (Anthropic Claude)
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# COINGECKO API (free demo key from coingecko.com/en/api/pricing)
# ============================================
COINGECKO_API_KEY=your-coingecko-demo-api-key

# ============================================
# CRYPTOCOMPARE API (free key from cryptocompare.com/cryptopiano/api-keys)
# ============================================
CRYPTOCOMPARE_API_KEY=your-cryptocompare-api-key
